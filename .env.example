NEXT_PUBLIC_SUPABASE_URL=https://shloeixwkwzyxwwzmkmh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNobG9laXh3a3d6eXh3d3pta21oIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQwMjI1NzgsImV4cCI6MjA4OTU5ODU3OH0.Pdc3neAfOgBffJgCND6KOiFaA1jIMnTe_Sc38dUkW6c
# Server-side only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ======================
# FRONTEND (Next.js)
# ======================
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal URL for server-side BFF proxy (used by api-client.ts when running on server)
BACKEND_INTERNAL_URL=http://127.0.0.1:5000

# ======================
# SIGNALR (Real-time Stock Prices)
# ======================
# URL for SignalR hub connection. In browser, use same-origin /bff/hubs/stock-price via Next.js BFF proxy.
# Set to full URL when deploying (e.g. https://your-api-domain.com).
NEXT_PUBLIC_SIGNALR_URL=

# ======================
# BACKEND (ASP.NET Core)
# ======================
ConnectionStrings__DefaultConnection=Host=db.shloeixwkwzyxwwzmkmh.supabase.co;Database=postgres;Username=postgres;Password=your-db-password
Redis__ConnectionString=localhost:6379
PythonService__BaseUrl=http://localhost:8000
Jwt__SecretKey=your-super-secret-key-min-32-characters-long-here
Jwt__Issuer=velo-api
Jwt__Audience=velo-client
Jwt__ExpiryDays=7
CoinGecko__BaseUrl=https://api.coingecko.com/api/v3
CoinGecko__ApiKey=
AllowedOrigins__0=http://localhost:3000
AllowedOrigins__1=https://velo.vercel.app

# ======================
# PYTHON AI SERVICE (FastAPI)
# ======================
MODEL_DIR=./app/models
LOG_LEVEL=INFO
PYTHON_SERVICE_HOST=0.0.0.0
PYTHON_SERVICE_PORT=8000

# ======================
# DEPLOYMENT URLS (Update when deployed)
# ======================
DEPLOY_FRONTEND_URL=https://velo.vercel.app
DEPLOY_BACKEND_URL=https://your-railway-app.railway.app
DEPLOY_PYTHON_URL=https://your-python-railway-app.railway.app
