# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase or self-hosted)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres

# ── Redis ────────────────────────────────────────────────────────────────────
# Redis connection string (Supabase or self-hosted)
REDIS_URL=redis://default:[YOUR-REDIS-PASSWORD]@[YOUR-HOST]:6379

# ── JWT Authentication ────────────────────────────────────────────────────────
# MUST be at least 32 characters. Generate with: openssl rand -base64 32
# Used to sign Velo API JWTs (exchange/login fallback). When SUPABASE_* is set, the API still accepts these tokens (watchlist, etc.) in addition to Supabase JWTs.
JWT_SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-32-CHARS-MINIMUM
JWT_EXPIRY_DAYS=7

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of admin emails (case-insensitive)
ADMIN_EMAIL=admin@velo.finance

# ── CORS / URLs ───────────────────────────────────────────────────────────────
# Frontend URL (for CORS headers)
FRONTEND_URL=http://localhost:3000

# ── External Services ─────────────────────────────────────────────────────────
# Python AI Service URL (for LSTM + Prophet predictions)
PYTHON_AI_SERVICE_URL=http://localhost:8000

# ── Environment ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
